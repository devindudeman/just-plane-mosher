# Location: Haight-Ashbury, San Francisco
LATITUDE=37.7692
LONGITUDE=-122.4488
RADIUS_NM=25

# Stadia Maps API key (optional for localhost, required for production)
STADIA_API_KEY=

# Display refresh interval in seconds
REFRESH_INTERVAL=120

# Logging level
LOG_LEVEL=INFO

# Set to "true" to render PNGs to output/ instead of driving the physical display
MOCK_DISPLAY=true
